    },
    {
      "no": "02",
      "title": "材料转译",
      "text": "把瓦灰、木褐、冷青、朱砂和砖石触感转成当代材料、色彩与界面系统。"
    },
    {
      "no": "03",
      "title": "数字预演",
      "text": "通过图纸、模型台和全景场景提前测试空间氛围、观看路径和维护方式。"
